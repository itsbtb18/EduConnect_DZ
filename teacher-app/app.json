{
  "expo": {
    "name": "EduConnect — Enseignant",
    "slug": "educonnect-teacher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "educonnect",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B3E"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B3E"
      },
      "package": "com.educonnect.teacher"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "EduConnect accède à vos photos pour joindre des fichiers.",
          "cameraPermission": "EduConnect accède à votre caméra."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ]
  }
}

