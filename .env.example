# ============================================================
# ILMI — Environment Variables
# ============================================================
# Copy this file:  cp .env.example .env
# Then fill in the values for your environment.

# ── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=ilmi.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api,ilmi-api

# ── Database (PostgreSQL 16) ────────────────────────────────
DB_NAME=ilmi_db
DB_USER=ilmi_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DB_PORT_EXTERNAL=5433

# ── Redis 7 ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6380

# ── Celery ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email (SMTP) ────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ilmi.dz

# ── Firebase (Push Notifications) ───────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# ── File Storage (S3 / Cloudflare R2 — production only) ────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=ilmi-files
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=

# ── AI Chatbot (RAG — PRO_AI plan only) ────────────────────
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ilmi-knowledge

# ── Sentry (Error Monitoring — production only) ─────────────
SENTRY_DSN=

# ── Security (production only) ──────────────────────────────
SECURE_SSL_REDIRECT=False
